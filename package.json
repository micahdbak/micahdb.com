{
  "name": "micahdb.com",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "copy-public": "mkdir -p build && cp -r ./public/* ./build",
    "build": "bun run copy-public && bun build ./src/index.ts --outdir ./build && bun build ./src/glyphatlas.ts --outdir ./build",
    "dev": "bun run copy-public && bun build ./src/index.ts --outdir ./build --watch",
    "lint": "eslint src",
    "format": "prettier --write src",
    "deploy": "bun run build && gh-pages -d build"
  },
  "prettier": {
    "useTabs": true,
    "trailingComma": "none"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "eslint": "^10.4.1",
    "gh-pages": "^6.3.0",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "mdast": "^3.0.0",
    "mdast-util-from-markdown": "^2.0.3",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.60.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
