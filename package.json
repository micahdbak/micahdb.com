{
  "name": "micahdb.com",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "copy-public": "mkdir -p build && cp -r ./public/* ./build",
    "build": "bun run copy-public && bun build ./src/index.ts --outdir ./build",
    "dev": "bun run copy-public && bun build ./src/index.ts --outdir ./build --watch"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
