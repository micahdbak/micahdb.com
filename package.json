{
  "name": "micahdb.com",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "copy-public": "mkdir -p build && cp -r ./public/* ./build",
    "build": "bun run copy-public && bun build ./src/index.ts --outdir ./build",
    "dev": "bun run copy-public && bun build ./src/index.ts --outdir ./build --watch",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "prettier": {
    "useTabs": true,
    "trailingComma": "none"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.58.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
